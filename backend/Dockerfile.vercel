# Crawl4AI Web UI — backend container image for Vercel Functions
# Vercel's container registry rejects large layer blobs (413 PAYLOAD_TOO_LARGE),
# so the Python deps and each browser binary are installed in separate RUN
# instructions to keep every layer well under the per-blob cap.
FROM python:3.13-slim

WORKDIR /app

ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

RUN apt-get update && apt-get install -y --no-install-recommends \
    libglib2.0-0 libnss3 libnspr4 libdbus-1-3 libatk1.0-0 libatk-bridge2.0-0 \
    libcups2 libxkbcommon0 libatspi2.0-0 libxcomposite1 libxdamage1 libxfixes3 \
    libxrandr2 libgbm1 libasound2 libcairo2 libpango-1.0-0 fonts-liberation \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt requirements.txt

# Heaviest dependencies first, in their own layer (~470MB uncompressed)
RUN pip install --no-cache-dir playwright patchright litellm scipy \
    && find /usr/local/lib/python3.13 -depth -type d -name __pycache__ -exec rm -rf {} +

# Remaining dependencies (~260MB uncompressed)
RUN pip install --no-cache-dir -r requirements.txt \
    && find /usr/local/lib/python3.13 -depth -type d -name __pycache__ -exec rm -rf {} +

# Browser binaries, one layer each (headless shell serves headless=True crawls)
RUN python -m playwright install chromium-headless-shell
RUN python -m playwright install chromium --no-shell

COPY app/ app/

# Vercel serverless containers have a read-only rootfs; only /tmp is writable.
# Both our app data AND crawl4ai's own home dir (which it creates at import time
# via os.makedirs on CRAWL4_AI_BASE_DIRECTORY/.crawl4ai, defaulting to ~/.crawl4ai)
# must therefore live under /tmp, or the import crashes the whole app.
# (Data is ephemeral per the platform — see README on hosting caveats.)
ENV C4AI_WEBUI_DATA=/tmp/c4ai-webui-data \
    CRAWL4_AI_BASE_DIRECTORY=/tmp \
    HOME=/tmp \
    PORT=80
EXPOSE 80

CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-80}"]
